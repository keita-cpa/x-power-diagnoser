# ══════════════════════════════════════════════════════════════
# x-integrated-platform — モノレポレベル .gitignore
# ══════════════════════════════════════════════════════════════

# ── シークレット・認証情報（絶対コミット禁止）──────────────────
.env
.env.*
!.env.example
*.pem
**/config.py

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── 仮想環境 ──────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/cache
.yarn/unplugged
.pnp.*

# ── CSVデータ（ローカル・本番それぞれ管理）────────────────────
apps/auto-poster/data/**/*.csv
apps/auto-poster/data/raw/

# ── 個人情報・プライバシー ────────────────────────────────────
apps/auto-poster/tone_sample_*.txt
apps/auto-poster/自動生成用ナレッジ/knowledge.xlsx
apps/auto-poster/drafts/

# ── ランタイム生成ファイル ────────────────────────────────────
apps/auto-poster/schedule.json
apps/auto-poster/temp_post_image.jpg
apps/auto-poster/data/drafts/stock_posts_draft.csv

# ── Claude Code ローカル設定 ──────────────────────────────────
**/.claude/settings.local.json

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── ログ ──────────────────────────────────────────────────────
*.log
logs/
!apps/auto-poster/data/logs/.gitkeep

# ── テスト・カバレッジ ────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/
